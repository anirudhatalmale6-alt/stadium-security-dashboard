      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT ROUND(AVG(achievement_pct)::numeric, 1) as \"Overall Score\" FROM v_kpi_status WHERE event_name = '${event}' AND achievement_pct IS NOT NULL",
